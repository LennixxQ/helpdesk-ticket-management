@using HelpDesk.Domain.Entities
@model SecurityEmailModel

<!DOCTYPE html>
<html>
<body style="margin:0;padding:0;font-family:'Segoe UI',Roboto,Helvetica,Arial,sans-serif;background-color:#f8fafc;">
    <div style="max-width:600px;margin:20px auto;background-color:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 4px 15px rgba(0,0,0,0.05);border:1px solid #e2e8f0;">
        <!-- Header -->
        <div style="background-color:#1e293b;padding:30px;text-align:center;">
            <h1 style="color:#ffffff;margin:0;font-size:24px;letter-spacing:1px;font-weight:600;">@Model.SystemName</h1>
            <p style="color:#94a3b8;margin:5px 0 0 0;font-size:14px;text-transform:uppercase;letter-spacing:2px;">Security Alert</p>
        </div>

        <!-- Content -->
        <div style="padding:40px;color:#334155;">
            <h2 style="color:#1e293b;margin-top:0;font-size:20px;">Password Changed Successfully</h2>
            <p style="font-size:16px;line-height:1.6;">Hello <strong>@Model.RecipientName</strong>,</p>
            <p style="font-size:16px;line-height:1.6;color:#475569;">
                This is an automated notification to confirm that your account password was changed on 
                <span style="font-weight:600;color:#1e293b;">@Model.ActionTimestamp.ToString("MMMM dd, yyyy") at @Model.ActionTimestamp.ToString("HH:mm") UTC</span>.
            </p>

            <!-- Security Warning Box -->
            <div style="margin:30px 0;padding:20px;background-color:#fef2f2;border-left:4px solid #ef4444;border-radius:4px;">
                <p style="margin:0;color:#991b1b;font-weight:600;font-size:15px;">Didn't do this?</p>
                <p style="margin:5px 0 0 0;color:#b91c1c;font-size:14px;line-height:1.5;">
                    If you did not change your password, your account may be compromised. Please <strong>contact your system administrator</strong> or IT department immediately to secure your access.
                </p>
            </div>

            <p style="font-size:14px;color:#64748b;line-height:1.6;margin-bottom:0;">
                For your security, all other active sessions have been automatically logged out. You will need to log in again on all your devices using your new password.
            </p>
        </div>

        <!-- Footer -->
        <div style="padding:20px 40px;background-color:#f1f5f9;text-align:center;border-top:1px solid #e2e8f0;">
            <p style="margin:0;font-size:12px;color:#94a3b8;">
                &copy; @DateTime.UtcNow.Year @Model.SystemName Support Team. All rights reserved.<br>
                This is an automated message, please do not reply.
            </p>
        </div>
    </div>
</body>
</html>
