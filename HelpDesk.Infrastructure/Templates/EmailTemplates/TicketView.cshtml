@using HelpDesk.Application.DTOs.Ticket
@model TicketDto

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Ticket #@Model.Id.ToString().Substring(0, 8).ToUpper()</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #f4f7f6; color: #333; margin: 0; padding: 20px; display: flex; justify-content: center; }
        .card { background: white; padding: 40px; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); width: 100%; max-width: 700px; }
        .header { border-bottom: 2px solid #eee; padding-bottom: 20px; margin-bottom: 20px; }
        h1 { margin: 0; color: #2c3e50; font-size: 24px; }
        .status { display: inline-block; padding: 5px 12px; border-radius: 20px; font-size: 12px; font-weight: bold; text-transform: uppercase; margin-top: 10px; }
        
        /* Status Colors */
        .status-open { background: #e3f2fd; color: #1976d2; }
        .status-inprogress { background: #fffde7; color: #fbc02d; }
        .status-onhold { background: #fce4ec; color: #d81b60; }
        .status-resolved { background: #e8f5e9; color: #2e7d32; }
        .status-closed { background: #eceff1; color: #455a64; }
        .status-reopened { background: #fff3e0; color: #ef6c00; }
        .status-escalated { background: #ffebee; color: #c62828; border: 1px solid #ef5350; }

        .meta { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 20px 0; font-size: 14px; }
        .meta-item { display: flex; flex-direction: column; }
        .label { color: #95a5a6; font-weight: bold; margin-bottom: 5px; font-size: 11px; text-transform: uppercase; }
        .desc { line-height: 1.6; background: #fafafa; padding: 20px; border-radius: 8px; border-left: 4px solid #3498db; white-space: pre-wrap; }
        .footer { margin-top: 30px; font-size: 12px; color: #bdc3c7; text-align: center; border-top: 1px solid #eee; padding-top: 20px; }
        
        .badge-escalated { 
            background: #d32f2f; color: white; padding: 2px 8px; border-radius: 4px; font-size: 10px; vertical-align: middle; margin-left: 10px;
        }
    </style>
</head>
<body>
    <div class='card'>
        <div class='header'>
            <h1>@Model.Title</h1>
            <div class='status status-@Model.Status.ToString().ToLower()'>@Model.Status</div>
            @if (Model.IsEscalated)
            {
                <span class="badge-escalated">ESCALATED</span>
            }
        </div>
        
        <div class='meta'>
            <div class='meta-item'>
                <span class='label'>Priority</span>
                <span>@Model.Priority</span>
            </div>
            <div class='meta-item'>
                <span class='label'>Category</span>
                <span>@Model.CategoryName</span>
            </div>
            <div class='meta-item'>
                <span class='label'>Raised By</span>
                <span>@(Model.RaisedByUser?.FullName ?? "N/A")</span>
            </div>
            <div class='meta-item'>
                <span class='label'>Created At</span>
                <span>@Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</span>
            </div>
            @if (Model.AssignedAgent != null)
            {
                <div class='meta-item'>
                    <span class='label'>Assigned Agent</span>
                    <span>@Model.AssignedAgent.FullName</span>
                </div>
            }
            @if (Model.SlaDeadline.HasValue)
            {
                <div class='meta-item'>
                    <span class='label'>SLA Deadline</span>
                    <span style="color: @(Model.SlaBreached ? "#c62828" : "inherit")">
                        @Model.SlaDeadline.Value.ToString("MMM dd, yyyy HH:mm")
                        @(Model.SlaBreached ? " (BREACHED)" : "")
                    </span>
                </div>
            }
        </div>

        <div class='meta-item'>
            <span class='label'>Description</span>
            <div class='desc'>@Model.Description</div>
        </div>

        @if (Model.Comments.Any())
        {
            <div style="margin-top: 30px;">
                <span class='label'>Recent Comments</span>
                @foreach (var comment in Model.Comments.OrderByDescending(c => c.CreatedAt).Take(5))
                {
                    <div style="font-size: 13px; margin-top: 10px; border-bottom: 1px solid #f0f0f0; padding-bottom: 10px;">
                        <strong>@comment.AuthorName</strong> 
                        <span style="color: #bdc3c7; font-size: 11px;">@comment.CreatedAt.ToString("MMM dd, HH:mm")</span>
                        <div style="margin-top: 5px; color: #555;">@comment.Content</div>
                    </div>
                }
            </div>
        }

        <div class='footer'>
            Generated by HelpDesk Template Engine — @DateTime.UtcNow.ToString("yyyy")
        </div>
    </div>
</body>
</html>
