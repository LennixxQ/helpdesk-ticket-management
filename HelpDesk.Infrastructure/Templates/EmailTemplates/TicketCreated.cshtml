@model HelpDesk.Infrastructure.Templates.TicketEmailModel
<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8"/>
  <style>
    body { font-family: Arial, sans-serif; background: #f4f4f4; margin: 0; padding: 0; }
    .container { max-width: 600px; margin: 30px auto; background: #fff; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
    .header { background: #1F3864; padding: 24px 32px; }
    .header h1 { color: #fff; margin: 0; font-size: 22px; }
    .header p { color: #a8c4e0; margin: 4px 0 0; font-size: 13px; }
    .body { padding: 32px; }
    .badge { display: inline-block; padding: 4px 12px; border-radius: 12px; font-size: 12px; font-weight: bold; }
    .badge-open       { background: #dbeafe; color: #1e40af; }
    .badge-inprogress { background: #fef9c3; color: #854d0e; }
    .badge-resolved   { background: #dcfce7; color: #166534; }
    .badge-closed     { background: #f1f5f9; color: #475569; }
    .badge-onhold     { background: #fce7f3; color: #9d174d; }
    .info-table { width: 100%; border-collapse: collapse; margin: 20px 0; }
    .info-table td { padding: 10px 12px; border-bottom: 1px solid #e2e8f0; font-size: 14px; }
    .info-table td:first-child { color: #64748b; width: 140px; font-weight: 600; }
    .btn { display: inline-block; background: #1F3864; color: #fff !important; padding: 12px 28px; border-radius: 6px; text-decoration: none; font-size: 14px; font-weight: 600; margin: 20px 0; }
    .footer { background: #f8fafc; padding: 20px 32px; text-align: center; font-size: 12px; color: #94a3b8; border-top: 1px solid #e2e8f0; }
    .footer a { color: #64748b; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>@Model.SystemName</h1>
      <p>Ticket Notification</p>
    </div>
    <div class="body">
      <p style="font-size:16px; color:#1e293b; margin-top:0;">
        Hi <strong>@Model.RecipientName</strong>,
      </p>
      <p style="color:#475569; font-size:14px;">@Model.MessageBody</p>

      <table class="info-table">
        <tr>
          <td>Ticket ID</td>
          <td><strong>#@Model.TicketId</strong></td>
        </tr>
        <tr>
          <td>Title</td>
          <td>@Model.TicketTitle</td>
        </tr>
        <tr>
          <td>Status</td>
          <td><span class="badge badge-@Model.StatusClass">@Model.Status</span></td>
        </tr>
        <tr>
          <td>Priority</td>
          <td>@Model.Priority</td>
        </tr>
        <tr>
          <td>Category</td>
          <td>@Model.Category</td>
        </tr>
        @if (!string.IsNullOrEmpty(Model.AssignedAgent))
        {
          <tr>
            <td>Assigned To</td>
            <td>@Model.AssignedAgent</td>
          </tr>
        }
        @if (Model.SlaDeadline.HasValue)
        {
          <tr>
            <td>SLA Deadline</td>
            <td>@Model.SlaDeadline.Value.ToString("dd MMM yyyy, HH:mm") UTC</td>
          </tr>
        }
      </table>

      <a href="@Model.TicketUrl" class="btn">View Ticket →</a>
    </div>
    <div class="footer">
      <p>
        This email was sent by <strong>@Model.SystemName</strong> Help Desk.<br/>
        <a href="@Model.PreferencesUrl">Manage notification preferences</a>
        &nbsp;|&nbsp;
        Reply to this email to respond directly.
      </p>
    </div>
  </div>
</body>
</html>