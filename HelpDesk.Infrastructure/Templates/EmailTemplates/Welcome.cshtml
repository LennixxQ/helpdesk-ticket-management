@using HelpDesk.Domain.Entities
@model WelcomeEmailModel

<!DOCTYPE html>
<html>
<body style="margin:0;padding:0;font-family:'Segoe UI',Roboto,Helvetica,Arial,sans-serif;background-color:#f8fafc;">
    <div style="max-width:600px;margin:20px auto;background-color:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 4px 15px rgba(0,0,0,0.05);border:1px solid #e2e8f0;">
        <!-- Header -->
        <div style="background-color:#1F3864;padding:40px 30px;text-align:center;">
            <h1 style="color:#ffffff;margin:0;font-size:28px;letter-spacing:1px;font-weight:600;">Welcome to @Model.SystemName</h1>
            <p style="color:#94a3b8;margin:10px 0 0 0;font-size:16px;">We're excited to have you on board!</p>
        </div>

        <!-- Content -->
        <div style="padding:40px;color:#334155;">
            <p style="font-size:18px;line-height:1.6;margin-top:0;">Hello <strong>@Model.RecipientName</strong>,</p>
            <p style="font-size:16px;line-height:1.6;color:#475569;">
                Your account for the <strong>@Model.SystemName</strong> management portal has been successfully created. You can now log in and start managing your requests.
            </p>

            <!-- Login Details Box -->
            <div style="margin:30px 0;padding:25px;background-color:#f1f5f9;border-radius:8px;border:1px solid #e2e8f0;">
                <h3 style="margin:0 0 15px 0;font-size:14px;text-transform:uppercase;color:#64748b;letter-spacing:1px;">Your Login Credentials</h3>
                <table style="width:100%;border-collapse:collapse;">
                    <tr>
                        <td style="padding:8px 0;color:#64748b;font-size:14px;width:80px;">Email:</td>
                        <td style="padding:8px 0;color:#1e293b;font-weight:600;font-size:15px;">@Model.Email</td>
                    </tr>
                    <tr>
                        <td style="padding:8px 0;color:#64748b;font-size:14px;">Password:</td>
                        <td style="padding:8px 0;color:#1e293b;font-weight:600;font-size:15px;font-family:monospace;">@Model.TempPassword</td>
                    </tr>
                </table>
            </div>

            <!-- Action Button -->
            <div style="text-align:center;margin:35px 0;">
                <a href="@Model.LoginUrl" style="background-color:#1F3864;color:#ffffff;padding:14px 30px;text-decoration:none;border-radius:6px;font-weight:600;font-size:16px;display:inline-block;box-shadow:0 4px 6px rgba(31,56,100,0.2);">
                    Login to Portal
                </a>
            </div>

            <div style="padding:20px;background-color:#fffbeb;border-radius:6px;border:1px solid #fef3c7;margin-top:30px;">
                <p style="margin:0;font-size:14px;color:#92400e;line-height:1.5;">
                    <strong>Important:</strong> For security reasons, you will be required to change this temporary password immediately after your first login.
                </p>
            </div>
        </div>

        <!-- Footer -->
        <div style="padding:30px 40px;background-color:#f8fafc;text-align:center;border-top:1px solid #e2e8f0;">
            <p style="margin:0;font-size:12px;color:#94a3b8;">
                &copy; @DateTime.UtcNow.Year @Model.SystemName Support Team. All rights reserved.<br>
                Need help? Contact our support desk.
            </p>
        </div>
    </div>
</body>
</html>
